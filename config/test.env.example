# =============================================================================
# Test Kit Configuration
# Copy this file to config/test.env and adjust for your Laravel project.
# =============================================================================

# Absolute path to the Laravel application under test (required)
PROJECT_ROOT=/path/to/your/laravel-app

# API base URL (include version prefix if your API is versioned)
BASE_URL=http://127.0.0.1:8000/api/v1

# Public app URL (used by E2E Playwright tests)
APP_URL=http://127.0.0.1:8000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8000

# Domain suffix for dynamically created test users
TEST_EMAIL_DOMAIN=test.example.com

# Authentication strategy:
#   mint_token  — fast, deterministic; runs a PHP script against your app (recommended)
#   http_login  — register/login via HTTP (slower, tests real auth flow)
AUTH_STRATEGY=mint_token

# Path to your mint-token adapter (see scripts/adapters/README.md)
# Options: scripts/adapters/generic/mint-token.php
#          scripts/adapters/laravel-modules/mint-token.php
MINT_TOKEN_SCRIPT=scripts/adapters/generic/mint-token.php

# JSON path for resource IDs in API responses (dot notation)
# Common values: data.id | id
JSON_ID_PATH=data.id

# Database seed command run before full suite (optional)
SEED_COMMAND=db:seed

# Set to 0 when testing production with valid TLS
CURL_INSECURE=1

# PHP binary
PHP_BIN=php

# -----------------------------------------------------------------------------
# Seeded users for policy / permission tests (must exist in your TestingSeeder)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@test.local
SEED_OWNER_EMAIL=user-01@test.local
SEED_CREATOR_EMAIL=user-02@test.local
SEED_MEMBER_EMAIL=user-03@test.local
SEED_AUTHOR_EMAIL=user-04@test.local
SEED_OTHER_EMAIL=user-05@test.local

# Optional: modular app adapter tuning (laravel-modules adapter only)
# USER_MODEL=Modules\\User\\Models\\User
# GLOBAL_ROLE_MODEL=Modules\\Project\\Models\\GlobalRole
# ADMIN_ROLE_NAME=Super Admin

# Optional: direct member assignment for fixture setup (PHP script path)
# ADD_MEMBER_SCRIPT=scripts/adapters/your-app/add-member.php

# Optional: pending registration model for E2E email verification tests
# PENDING_REGISTRATION_MODEL=App\\Models\\PendingRegistration
