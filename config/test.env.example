# =============================================================================
# Test Kit Configuration
# Copy this file to config/test.env and adjust for your Laravel project.
# =============================================================================

# Absolute path to the Laravel application under test (required)
PROJECT_ROOT=/path/to/your/laravel-app

# API base URL (include version prefix if your API is versioned)
BASE_URL=http://127.0.0.1:8000/api/v1

# Public app URL (used by E2E Playwright tests)
APP_URL=http://127.0.0.1:8000
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8000

# Domain suffix for dynamically created test users
TEST_EMAIL_DOMAIN=test.example.com

# Authentication strategy:
#   mint_token  — fast, deterministic; runs a PHP script against your app (recommended)
#   http_login  — register/login via HTTP (slower, tests real auth flow)
AUTH_STRATEGY=mint_token

# Path to your mint-token adapter (see scripts/adapters/README.md)
MINT_TOKEN_SCRIPT=scripts/adapters/finolo/mint-token.php

# JSON path for resource IDs in API responses (dot notation)
# Common values: data.id | id
JSON_ID_PATH=data.id

# Database seed command run before full suite (optional)
SEED_COMMAND=db:seed

# Set to 0 when testing production with valid TLS
CURL_INSECURE=1

# PHP binary
PHP_BIN=php

# -----------------------------------------------------------------------------
# Finolo-specific: seeded users for policy / permission tests
# Override these when adapting policy-fixtures.sh for your app
# -----------------------------------------------------------------------------
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_OWNER_EMAIL=owner@example.com
# SEED_MEMBER_EMAIL=member@example.com
