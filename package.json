{
  "name": "laravel-api-test-kit",
  "private": true,
  "type": "module",
  "description": "Portable API, workflow, and E2E test suite for Laravel applications",
  "scripts": {
    "setup": "bash scripts/setup-project.sh",
    "test:api": "bash api/run-all-api-tests.sh",
    "test:api:workspace": "bash api/test-workspace-api.sh",
    "postman:generate": "php postman/generate-collections.php",
    "postman:newman": "newman run postman/collections/api.json -e postman/environments/local.environment.json",
    "postman:newman:flows": "newman run postman/collections/api.json -e postman/environments/local.environment.json --folder Flows",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:perf": "k6 run performance/k6-api-load.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
